            <div style={{color:+result.lambda<0.8?t.danger:+result.lambda>2?t.warn:t.ok,fontSize:F.sm,
              marginTop:-4,marginBottom:8,padding:"5px 11px",background:t.inp,borderRadius:5}}>
              λ = {result.lambda} — {+result.lambda<0.8?"⚠ KAYA: tidak sempurna":+result.lambda>2?"⚠ MISKIN: boros panas":"✓ Stoikiometri OK"}
            </div>
          </Sec>

          <Sec title="Udara Sekunder" color={t.cyan} t={t}>
            <Slider t={t} label="Suhu Udara Sekunder" value={params.T_secondary_C} min={15} max={400} step={5} unit=" °C" color="#67e8f9"
              note={params.T_secondary_C>60?"✓ Udara panas percepat re-combustion":null} onChange={v=>set("T_secondary_C",v)}/>
            {params.injections.map(inj=>(
              <div key={inj.id} style={{background:t.inp,border:`1px solid ${t.bdr}`,borderRadius:7,padding:"11px 13px",marginBottom:11}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:9}}>
                  <span style={{color:t.cyan,fontSize:F.sm}}>Injeksi #{inj.id}</span>
                  <button onClick={()=>removeInj(inj.id)} style={{background:"none",border:`1px solid ${t.danger}44`,borderRadius:4,color:t.danger,fontSize:F.xs,padding:"2px 8px",cursor:"pointer"}}>✕</button>
                </div>
                <Slider t={t} label="Posisi (%H)" value={inj.h_pct} min={5} max={95} step={5} unit="%" color={t.cyan} onChange={v=>updInj(inj.id,"h_pct",v)}/>
                <Slider t={t} label="Laju Alir" value={inj.flow_Lmin} min={0} max={80} step={2.5} unit=" L/min" color="#67e8f9" onChange={v=>updInj(inj.id,"flow_Lmin",v)}/>
