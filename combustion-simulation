/* ─── HELPERS ─────────────────────────────────────────────────────── */
function dAtH(hp,baseD,secs=[]){
  for(const s of [...secs].sort((a,b)=>b.h_pct-a.h_pct)) if(hp>=s.h_pct) return s.d;
  return baseD;
}

function simulate(p){
  const{d_port,d_riser,H_riser,feed_rate_kg_h,LHV_MJkg,moisture_pct,
    primary_air_Lmin,insulation,injections=[],riserSections=[],
    T_primary_C=25,T_secondary_C=25,fuelType="wood"}=p;
  const fuel=FUELS[fuelType]||FUELS.wood;
  const Tp=T_primary_C+273.15,Ts=T_secondary_C+273.15;
  const Ap=Math.PI/4*Math.max(d_port,0.01)**2,Ar=Math.PI/4*Math.max(d_riser,0.01)**2,aR=Ap/Ar;
  const mcf=moisture_pct/100,LHV_e=Math.max(0.1,LHV_MJkg*(1-mcf)-LATENT*mcf);
  const mdot=feed_rate_kg_h/3600,Qw=mdot*LHV_e*1e6;
  const rhop=Patm/(Rg*Tp),mp=(primary_air_Lmin/60/1000)*rhop;
  const mSt=mdot*fuel.afr,lam0=mSt>0?mp/mSt:1,m0=mp+mdot;
  const Tf=Math.min(T0+(Qw+mp*Cp*(Tp-T0))*Math.min(lam0,1.3)/(m0*Cp),1773);
  const injS=[...injections].sort((a,b)=>a.h_pct-b.h_pct);
  let Tc=Tf,mg=m0,lam=lam0;
  let CO=(lam0<1?Math.min(8000,7000*(1-lam0)+500):Math.max(50,600*Math.exp(-2*(lam0-1))))*fuel.em;
  const done=new Set(),profile=[];
  for(let i=0;i<=60;i++){
    const h=(i/60)*H_riser,hp=(i/60)*100,dL=dAtH(hp,d_riser,riserSections),AL=Math.PI/4*dL**2;
    for(let j=0;j<injS.length;j++){
      const inj=injS[j];
      if(!done.has(j)&&hp>=inj.h_pct&&inj.flow_Lmin>0){
        done.add(j);
        const mi=(inj.flow_Lmin/60/1000)*(Patm/(Rg*Ts));
        Tc=(mg*Tc+mi*Ts)/(mg+mi);mg+=mi;lam=mSt>0?(mg-mdot)/mSt:lam;
        Tc=Math.min(Tc+Math.max(0,1-lam0)*Qw*0.4*Math.min(1,mi/Math.max(mSt*0.3,1e-5))/(mg*Cp),1450);
        CO=Math.max(CO*(lam<1?0.65:0.08),8*fuel.em);
      }
    }
    const Uw=(1-(insulation/100))*8+(insulation/100)*0.3;
    Tc=Math.max(Tc-(Uw*Math.PI*dL*(H_riser/60)*(Tc-T0))/(mg*Cp),T0+10);
    const rhog=Patm/(Rg*Tc),v=mg>0?(mg/rhog)/AL:0,dP=RHO0*G*h*(1-T0/Tc);
    const NOx=Tc>1273?Math.min(300,0.06*(Tc-1273)*lam*fuel.em):0;
    const PM=Math.max(0.1,120*fuel.em*Math.exp(-0.005*(Tc-900))/Math.max(lam,0.5));
    profile.push({h:+h.toFixed(3),h_pct:+hp.toFixed(1),T_C:Math.round(Tc-273),
      CO_ppm:Math.round(CO),v:+v.toFixed(2),dP:+dP.toFixed(2),
      NOx:+NOx.toFixed(1),PM25:+PM.toFixed(2),d_local:+dL.toFixed(3)});
  }
  const last=profile[profile.length-1],Tex=last.T_C+273;
  const eff=Math.max(0,Math.min(70,(Qw-mg*Cp*(Tex-T0))/Qw*100));
  const draft=Math.max(0,(RHO0-Patm/(Rg*Tex))*G*H_riser);
  return{profile,A_port_cm2:(Ap*1e4).toFixed(2),A_riser_cm2:(Ar*1e4).toFixed(2),
    area_ratio:aR.toFixed(3),area_ok:aR>0.85&&aR<1.15,Q_kW:(Qw/1000).toFixed(2),
    T_flame_C:Math.round(Tf-273),T_exit_C:last.T_C,efficiency:eff.toFixed(1),
    draft_Pa:draft.toFixed(1),lambda:lam0.toFixed(2),CO_exit:last.CO_ppm,
    NOx_exit:last.NOx.toFixed(1),PM25_exit:last.PM25.toFixed(2)};
}

/* ─── OPTIMIZATION ────────────────────────────────────────────────── */
function scoreR(r,obj){
  const e=+r.efficiency,co=+r.CO_exit,nox=+r.NOx_exit,pm=+r.PM25_exit,lam=+r.lambda;
  const lamB=lam>=0.9&&lam<=1.8?12:-15,dB=+r.draft_Pa>8?5:0;
  if(obj==='eff')  return e*2-co*0.004-nox*0.05+lamB+dB;
  if(obj==='em')   return-(co*0.3+nox*1.2+pm*5)+e*0.5+lamB;
  return e*1.0+Math.max(0,60-co*0.06)*0.7+Math.max(0,15-nox)*0.4+Math.max(0,25-pm)*0.3+lamB+dB;
}
function runOpt(baseP,obj){
  const rnd=(lo,hi)=>lo+Math.random()*(hi-lo),all=[];
  for(let i=0;i<450;i++){
    const p={...baseP,primary_air_Lmin:+rnd(10,200).toFixed(0),T_primary_C:+rnd(20,350).toFixed(0),
      T_secondary_C:+rnd(20,350).toFixed(0),
      injections:baseP.injections.map(inj=>({...inj,flow_Lmin:+rnd(0,80).toFixed(1)}))};
    const r=simulate(p);all.push({p,r,score:scoreR(r,obj)});
  }
  all.sort((a,b)=>b.score-a.score);
  for(let k=0;k<3;k++){
    const bp=all[k].p;
    for(let i=0;i<60;i++){
      const pt=(v,lo,hi)=>Math.max(lo,Math.min(hi,v+(Math.random()-.5)*2*0.25*(hi-lo)));
      const p={...baseP,primary_air_Lmin:+pt(bp.primary_air_Lmin,10,200).toFixed(0),
        T_primary_C:+pt(bp.T_primary_C,20,350).toFixed(0),T_secondary_C:+pt(bp.T_secondary_C,20,350).toFixed(0),
        injections:bp.injections.map(inj=>({...inj,flow_Lmin:+Math.max(0,Math.min(80,inj.flow_Lmin+(Math.random()-.5)*24)).toFixed(1)}))};
      const r=simulate(p);all.push({p,r,score:scoreR(r,obj)});
    }
  }
  return all.sort((a,b)=>b.score-a.score).slice(0,5);
}

/* ─── SCHEMATIC (always dark for thermal viz) ─────────────────────── */
function Schematic({params,result}){
  const W=340,H=420,ml=68,mb=36,mt=38;
  const sh=H-mt-mb,horiz_h=44,horiz_w=(W-ml-30)*0.44;
  const riser_h=sh*0.73,base_y=H-mb,riser_y=base_y-riser_h;
  const riserCX=ml+horiz_w,horiz_y=base_y-horiz_h;
  const D_REF=0.30,W_HALF=25,dToHW=d=>Math.max(5,(d/D_REF)*W_HALF),hToY=hp=>base_y-(hp/100)*riser_h;
  const sortedRS=[...(params.riserSections||[])].sort((a,b)=>a.h_pct-b.h_pct);
  const leftPts=[],rightPts=[];let curD=params.d_riser;
  leftPts.push([riserCX-dToHW(curD),hToY(0)]);rightPts.push([riserCX+dToHW(curD),hToY(0)]);
  for(const rs of sortedRS){
    const y=hToY(rs.h_pct);
    leftPts.push([riserCX-dToHW(curD),y],[riserCX-dToHW(rs.d),y]);
    rightPts.push([riserCX+dToHW(curD),y],[riserCX+dToHW(rs.d),y]);
    curD=rs.d;
  }
  leftPts.push([riserCX-dToHW(curD),hToY(100)]);rightPts.push([riserCX+dToHW(curD),hToY(100)]);
  const poly=[...leftPts,...[...rightPts].reverse()].map(p=>p.join(',')).join(' ');
  const maxHW=Math.max(...[params.d_riser,...(params.riserSections||[]).map(s=>s.d)].map(dToHW))+12;
  const tColor=T=>{const t=Math.max(0,Math.min(1,(T-100)/900));return`rgb(${Math.round(255*Math.min(1,t*2))},${Math.round(255*Math.max(0,1-Math.abs(t-.5)*3))},${Math.round(255*Math.max(0,1-t*2))})`};
  const getTc=hp=>(result.profile.find(p=>Math.abs(p.h_pct-hp)<3)||{T_C:500}).T_C;
  const gs=Array.from({length:9},(_,i)=>({pct:i/8*100,c:tColor(getTc(100-i/8*100))}));
  const activeInj=(params.injections||[]).filter(i=>i.flow_Lmin>0);
  const fuel=FUELS[params.fuelType]||FUELS.wood;
  const MK=[["aU","M0,6L3,0L6,6","rgba(255,255,255,.55)"],["aR","M0,0L6,3L0,6",fuel.c],["aS","M0,0L6,3L0,6","#22d3ee"],["aP","M0,0L6,3L0,6","#3b82f6"]];
  return(
    <svg width={W} height={H} viewBox={`0 0 ${W} ${H}`} style={{width:"100%",height:"100%"}}>
      <defs>
        <linearGradient id="rG" x1="0" y1="1" x2="0" y2="0">{gs.map((s,i)=><stop key={i} offset={`${s.pct}%`} stopColor={s.c} stopOpacity=".9"/>)}</linearGradient>
        <linearGradient id="hG" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stopColor="#1e3a5f"/><stop offset="100%" stopColor="#dc4e0c" stopOpacity=".95"/></linearGradient>
        <filter id="gw"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <pattern id="grd" width="10" height="10" patternUnits="userSpaceOnUse"><path d="M10 0L0 0 0 10" fill="none" stroke="#0e1a2a" strokeWidth=".5"/></pattern>
        {MK.map(([id,d,fill])=><marker key={id} id={id} markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto"><path d={d} fill={fill}/></marker>)}
      </defs>
      <rect width={W} height={H} fill="url(#grd)"/>
      <rect x={riserCX-maxHW} y={riser_y-12} width={maxHW*2} height={riser_h+24} fill="#111d2e" rx="3" stroke="#2a3f5f" strokeWidth="1"/>
      <rect x={ml-8} y={horiz_y-8} width={horiz_w+8} height={horiz_h+16} fill="#111d2e" rx="3" stroke="#2a3f5f" strokeWidth="1"/>
      <rect x={ml} y={horiz_y} width={horiz_w} height={horiz_h} fill="url(#hG)" rx="2" stroke="#f97316" strokeWidth="1.5" opacity=".95"/>
      <text x={ml+horiz_w/2} y={horiz_y-15} textAnchor="middle" fill="#9ca3af" fontSize="8.5" fontFamily="monospace">COMBUSTION CHAMBER</text>
      <text x={ml+horiz_w/2} y={horiz_y-4} textAnchor="middle" fill="#f97316" fontSize="7.5" fontFamily="monospace">L={(params.L_horiz*100).toFixed(0)}cm · ⌀={(params.d_port*100).toFixed(0)}cm</text>
      <text x={ml+horiz_w/2} y={horiz_y+horiz_h/2+5} textAnchor="middle" fill="#fbbf24" fontSize="13" fontWeight="bold" fontFamily="monospace" filter="url(#gw)">{result.T_flame_C}°C</text>
      <polygon points={poly} fill="url(#rG)" stroke="#f97316" strokeWidth="1.5" filter="url(#gw)"/>
      {sortedRS.map((rs,i)=>{const y=hToY(rs.h_pct),hw=dToHW(rs.d);return(<g key={i}><line x1={riserCX-hw-2} y1={y} x2={riserCX+hw+2} y2={y} stroke="#06b6d4" strokeWidth="1.2" strokeDasharray="3 2"/><text x={riserCX+hw+6} y={y+4} fill="#06b6d4" fontSize="7.5" fontFamily="monospace">⌀{(rs.d*100).toFixed(0)}@{rs.h_pct}%</text></g>);})}
      {[.18,.42,.68,.88].map((f,i)=><line key={i} x1={riserCX} y1={riser_y+riser_h*(1-f)+9} x2={riserCX} y2={riser_y+riser_h*(1-f)-9} stroke="rgba(255,255,255,.4)" strokeWidth="1.5" markerEnd="url(#aU)"/>)}
      <text x={riserCX+maxHW+4} y={riser_y+12} fill="#9ca3af" fontSize="8.5" fontFamily="monospace">HEAT RISER</text>
      <text x={riserCX+maxHW+4} y={riser_y+24} fill="#22d3ee" fontSize="8" fontFamily="monospace">H={params.H_riser.toFixed(2)}m</text>
      <text x={riserCX+maxHW+4} y={riser_y+36} fill="#22d3ee" fontSize="8" fontFamily="monospace">⌀={(params.d_riser*100).toFixed(0)}cm</text>
      <line x1={ml-32} y1={horiz_y+horiz_h*.45} x2={ml-2} y2={horiz_y+horiz_h*.45} stroke={fuel.c} strokeWidth="2" strokeDasharray="4 2" markerEnd="url(#aR)"/>
      <text x={ml-34} y={horiz_y+horiz_h*.45-7} fill={fuel.c} fontSize="9" textAnchor="end" fontFamily="monospace">{fuel.icon}</text>
      <text x={ml-34} y={horiz_y+horiz_h*.45+5} fill={fuel.c} fontSize="7.5" textAnchor="end" fontFamily="monospace">{params.feed_rate_kg_h}kg/h</text>
      <line x1={ml-32} y1={base_y-10} x2={ml-2} y2={horiz_y+horiz_h-6} stroke="#3b82f6" strokeWidth="1.5" strokeDasharray="3 2" markerEnd="url(#aP)"/>
      <text x={ml-34} y={base_y-17} fill="#3b82f6" fontSize="8" textAnchor="end" fontFamily="monospace">AIR₁</text>
      <text x={ml-34} y={base_y-6} fill="#3b82f6" fontSize="7.5" textAnchor="end" fontFamily="monospace">{params.primary_air_Lmin}L/m</text>
      <text x={ml-34} y={base_y+5} fill="#60a5fa" fontSize="7.5" textAnchor="end" fontFamily="monospace">{params.T_primary_C}°C</text>
      {activeInj.map((inj,idx)=>{const iy=hToY(inj.h_pct),ix=riserCX-dToHW(dAtH(inj.h_pct,params.d_riser,params.riserSections||[]));return(<g key={idx} filter="url(#gw)"><line x1={ix-28} y1={iy} x2={ix-2} y2={iy} stroke="#22d3ee" strokeWidth="1.5" strokeDasharray="3 2" markerEnd="url(#aS)"/><circle cx={ix} cy={iy} r="4" fill="#22d3ee" opacity=".75"/><text x={ix-30} y={iy-5} fill="#22d3ee" fontSize="7.5" fontFamily="monospace" textAnchor="end">AIR₂@{inj.h_pct}%</text><text x={ix-30} y={iy+7} fill="#67e8f9" fontSize="7" fontFamily="monospace" textAnchor="end">{inj.flow_Lmin}L/m·{params.T_secondary_C}°C</text></g>);})}
      <line x1={riserCX} y1={riser_y-2} x2={riserCX} y2={riser_y-24} stroke="#f97316" strokeWidth="2" strokeDasharray="4 2" markerEnd="url(#aU)" filter="url(#gw)"/>
      <text x={riserCX+maxHW+4} y={riser_y-14} fill="#f97316" fontSize="8" fontFamily="monospace">EXHAUST {result.T_exit_C}°C</text>
      {(()=>{const rx=riserCX-maxHW-14;return(<><line x1={rx} y1={riser_y} x2={rx} y2={base_y} stroke="#1e3a5f" strokeWidth="1"/>{[0,.25,.5,.75,1].map((f,i)=>{const ry=riser_y+riser_h*f;return(<g key={i}><line x1={rx-4} y1={ry} x2={rx+4} y2={ry} stroke="#334155" strokeWidth="1"/><text x={rx-6} y={ry+3} textAnchor="end" fill="#334155" fontSize="7" fontFamily="monospace">{((1-f)*params.H_riser).toFixed(1)}m</text></g>);})}</>);})()}
      <g transform={`translate(${W-62},${H-86})`}>
        <rect x="0" y="0" width="56" height="76" fill="#080f1e" stroke={result.area_ok?"#22c55e33":"#ef444433"} strokeWidth="1" rx="4"/>
        <text x="28" y="13" textAnchor="middle" fill="#94a3b8" fontSize="7.5" fontFamily="monospace">AREA CHECK</text>
        <rect x="8" y="20" width={Math.min(40,40*+result.A_port_cm2/Math.max(+result.A_riser_cm2,.01))} height="11" fill={result.area_ok?"#22c55e":"#ef4444"} rx="1" opacity=".8"/>
        <rect x="8" y="35" width="40" height="11" fill="#f97316" rx="1" opacity=".6"/>
        <text x="28" y="30" textAnchor="middle" fill="white" fontSize="6.5" fontFamily="monospace">PORT</text>
        <text x="28" y="45" textAnchor="middle" fill="white" fontSize="6.5" fontFamily="monospace">RISER</text>
        <text x="28" y="60" textAnchor="middle" fill={result.area_ok?"#22c55e":"#ef4444"} fontSize="9" fontFamily="monospace" fontWeight="bold">{result.area_ratio}</text>
        <text x="28" y="71" textAnchor="middle" fill={result.area_ok?"#22c55e":"#ef4444"} fontSize="7" fontFamily="monospace">{result.area_ok?"✓ BALANCED":"⚠ ADJUST"}</text>
      </g>
    </svg>
  );
}

/* ─── PRIMITIVES ──────────────────────────────────────────────────── */
function Gauge({label,value,max,unit,warn,good,t}){
  const pct=Math.min(100,(value/max)*100),c=value>=good?t.ok:value>=warn?t.warn:t.danger;
  return(
    <div style={{marginBottom:13}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:5}}>
        <span style={{color:t.muted,fontSize:F.sm,fontFamily:"monospace"}}>{label}</span>
        <span style={{color:c,fontSize:F.md,fontFamily:"monospace",fontWeight:"bold"}}>{value}{unit}</span>
      </div>
      <div style={{background:t.inp,borderRadius:4,height:8,overflow:"hidden"}}>
        <div style={{width:`${pct}%`,height:"100%",borderRadius:4,background:`linear-gradient(90deg,${c}55,${c})`,transition:"width .4s",boxShadow:`0 0 8px ${c}44`}}/>
      </div>
    </div>
  );
}

function Slider({label,value,min,max,step,unit,onChange,color,warn,note,t}){
  const c=color||t.acc;
  return(
    <div style={{marginBottom:15}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:4}}>
        <label style={{color:t.muted,fontSize:F.sm,fontFamily:"monospace"}}>{label}</label>
        <span style={{color:warn?t.danger:c,fontSize:F.md,fontFamily:"monospace",fontWeight:"bold"}}>{value}{unit}</span>
      </div>
      <input type="range" min={min} max={max} step={step} value={value} onChange={e=>onChange(parseFloat(e.target.value))}
        style={{width:"100%",accentColor:c,cursor:"pointer",height:5}}/>
      {note&&<div style={{color:c+"aa",fontSize:F.xxs,marginTop:3}}>{note}</div>}
    </div>
  );
}

function Sec({title,children,color,t}){
