                  <div style={{marginTop:3,fontSize:F.xxs}}>{f.name}</div>
                </button>
              ))}
            </div>
            {params.fuelType==="mixedWaste"&&<div style={{color:t.warn,fontSize:F.xs,padding:"7px 11px",background:`${t.warn}11`,borderRadius:5,borderLeft:`2px solid ${t.warn}`,marginBottom:13}}>🗑️ Emisi lebih tinggi (×2.8). Pertimbangkan sortasi pra-bakar.</div>}
            {params.fuelType==="plastic"&&<div style={{color:t.danger,fontSize:F.xs,padding:"7px 11px",background:`${t.danger}11`,borderRadius:5,borderLeft:`2px solid ${t.danger}`,marginBottom:13}}>⚠ Dioksin &amp; HCl — butuh scrubber gas!</div>}
            <Slider t={t} label="Feed Rate" value={params.feed_rate_kg_h} min={.2} max={8} step={.1} unit=" kg/h" color="#fbbf24" onChange={v=>set("feed_rate_kg_h",v)}/>
            <Slider t={t} label="LHV (MJ/kg)" value={params.LHV_MJkg} min={3} max={35} step={.5} unit=" MJ/kg" color="#fbbf24" onChange={v=>set("LHV_MJkg",v)}/>
            <Slider t={t} label="Kadar Air" value={params.moisture_pct} min={0} max={60} step={1} unit="%" color="#f59e0b" onChange={v=>set("moisture_pct",v)}/>
            <Slider t={t} label="Insulasi" value={params.insulation} min={0} max={95} step={5} unit="%" color="#84cc16" onChange={v=>set("insulation",v)}/>
          </Sec>

          <Sec title="Udara Primer" color={t.blue} t={t}>
            <Slider t={t} label="Laju Alir Primer" value={params.primary_air_Lmin} min={5} max={200} step={5} unit=" L/min" color={t.blue} onChange={v=>set("primary_air_Lmin",v)}/>
            <Slider t={t} label="Suhu Udara Primer" value={params.T_primary_C} min={15} max={400} step={5} unit=" °C" color="#60a5fa"
