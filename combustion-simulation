    {k:'eff',     icon:"⚡",label:"Efisiensi Maks",  desc:"Maksimalkan efisiensi termal"},
    {k:'em',      icon:"🌿",label:"Emisi Minimum",    desc:"Minimalisasi CO, NOx, PM2.5"},
    {k:'balanced',icon:"⚖️",label:"Seimbang",         desc:"Keseimbangan efisiensi & emisi"},
  ];
  const run=()=>{
    setRunning(true);setResults(null);setProg(0);
    let p=0;const iv=setInterval(()=>{p+=Math.random()*15;setProg(Math.min(88,p));if(p>=88)clearInterval(iv);},90);
    setTimeout(()=>{
      const res=runOpt(params,obj);clearInterval(iv);setProg(100);
      setTimeout(()=>{setResults(res);setRunning(false);},280);
    },50);
  };
  const mColor=(k,r)=>{
    if(k==='efficiency') return +r.efficiency>=40?t.ok:+r.efficiency>=25?t.warn:t.danger;
    if(k==='CO_exit')    return +r.CO_exit<200?t.ok:+r.CO_exit<700?t.warn:t.danger;
    if(k==='NOx_exit')   return +r.NOx_exit<50?t.ok:+r.NOx_exit<150?t.warn:t.danger;
    if(k==='PM25_exit')  return +r.PM25_exit<10?t.ok:+r.PM25_exit<30?t.warn:t.danger;
    if(k==='lambda')     return +r.lambda>=0.9&&+r.lambda<=1.8?t.ok:t.warn;
    if(k==='draft_Pa')   return +r.draft_Pa>8?t.ok:t.warn;
    return t.txt;
  };
  const delta=(k,optR,inv=false)=>{
    const map={efficiency:+curResult.efficiency,CO_exit:+curResult.CO_exit,NOx_exit:+curResult.NOx_exit,PM25_exit:+curResult.PM25_exit,draft_Pa:+curResult.draft_Pa};
    if(!(k in map)) return null;
    const curr=map[k],opt=+optR[k],diff=opt-curr;
    if(Math.abs(diff)<0.5) return null;
    const pct=curr!==0?diff/Math.abs(curr)*100:0;
    const good=inv?diff<0:diff>0;
    return <span style={{fontSize:F.xxs,color:good?t.ok:t.danger,marginLeft:4}}>{diff>0?"+":""}{pct.toFixed(0)}%</span>;
  };
  return(
    <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden",padding:"18px 24px",background:t.panelBg}}>
      <div style={{fontSize:F.lg,fontWeight:"bold",color:t.acc,letterSpacing:".07em",marginBottom:8,fontFamily:"monospace"}}>🔧 MODUL OPTIMASI OTOMATIS</div>
      <div style={{color:t.muted,fontSize:F.sm,marginBottom:20,fontFamily:"monospace",lineHeight:1.6}}>
        Cari konfigurasi udara terbaik menggunakan Random Search + Local Refinement (630 iterasi). Geometri &amp; jenis bahan bakar dipertahankan. Parameter yang dioptimasi: laju alir primer, suhu primer, suhu sekunder, laju alir tiap titik injeksi.
      </div>
      {/* Objective */}
      <div style={{display:"flex",gap:10,marginBottom:22,flexWrap:"wrap"}}>
        {OBJS.map(o=>(
          <button key={o.k} onClick={()=>setObj(o.k)} style={{flex:"1 1 140px",padding:"13px 16px",borderRadius:9,cursor:"pointer",
            fontFamily:"monospace",background:obj===o.k?`${t.acc}18`:t.card,border:`1.5px solid ${obj===o.k?t.acc:t.bdr}`,
            color:obj===o.k?t.acc:t.muted,transition:"all .2s",textAlign:"left"}}>
            <div style={{fontSize:F.lg,marginBottom:4}}>{o.icon} <span style={{fontSize:F.md,fontWeight:"bold"}}>{o.label}</span></div>
            <div style={{fontSize:F.xxs,opacity:.8}}>{o.desc}</div>
          </button>
        ))}
      </div>
      {/* Run button */}
      <div style={{marginBottom:22}}>
        <button onClick={run} disabled={running} style={{
          background:running?t.dim:`linear-gradient(135deg,${t.acc},${t.acc}cc)`,border:"none",borderRadius:9,
          color:"white",fontSize:F.md,fontWeight:"bold",padding:"13px 36px",cursor:running?"not-allowed":"pointer",
          fontFamily:"monospace",letterSpacing:".06em",boxShadow:running?"none":`0 4px 18px ${t.acc}44`,transition:"all .3s"}}>
          {running?"⏳ Sedang menghitung...":"▶ Jalankan Optimasi"}
        </button>
        {prog>0&&(
          <div style={{marginTop:12}}>
            <div style={{display:"flex",justifyContent:"space-between",marginBottom:5}}>
              <span style={{color:t.muted,fontSize:F.sm,fontFamily:"monospace"}}>Progress simulasi</span>
              <span style={{color:t.acc,fontSize:F.sm,fontFamily:"monospace",fontWeight:"bold"}}>{Math.round(prog)}%</span>
            </div>
            <div style={{background:t.inp,borderRadius:4,height:9,overflow:"hidden"}}>
              <div style={{width:`${prog}%`,height:"100%",borderRadius:4,background:`linear-gradient(90deg,${t.acc}88,${t.acc})`,transition:"width .15s"}}/>
            </div>
          </div>
        )}
      </div>
      {/* Results */}
      {results&&(
        <div style={{flex:1,overflowY:"auto",minHeight:0}}>
          <div style={{fontSize:F.md,fontWeight:"bold",color:t.txt,marginBottom:16,fontFamily:"monospace"}}>
            📊 Top 5 Konfigurasi Terbaik &nbsp;<span style={{color:t.muted,fontSize:F.sm,fontWeight:"normal"}}>— vs. konfigurasi saat ini</span>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            {results.map((res,idx)=>(
              <div key={idx} style={{background:t.card,border:`1.5px solid ${idx===0?t.acc:t.bdr}`,
                borderRadius:11,padding:"18px 20px",position:"relative",boxShadow:idx===0?`0 0 22px ${t.acc}22`:t.shadow}}>
                {idx===0&&<div style={{position:"absolute",top:-11,left:18,background:t.acc,color:"white",
                  fontSize:F.xxs,fontWeight:"bold",padding:"2px 12px",borderRadius:10,fontFamily:"monospace"}}>🏆 TERBAIK</div>}
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:14,flexWrap:"wrap",gap:10}}>
                  <div>
                    <div style={{color:t.muted,fontSize:F.xs,fontFamily:"monospace",marginBottom:8}}>Rank #{idx+1} · Skor: {res.score.toFixed(1)}</div>
                    <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
                      {[
                        {l:"Primer",v:`${res.p.primary_air_Lmin}L/min · ${res.p.T_primary_C}°C`},
                        {l:"Sekunder",v:`${res.p.T_secondary_C}°C`},
                        ...res.p.injections.map((inj,i)=>({l:`Inj#${i+1}@${inj.h_pct}%`,v:`${inj.flow_Lmin}L/min`})),
                      ].map((item,i)=>(
                        <div key={i} style={{background:t.tag,borderRadius:6,padding:"6px 12px"}}>
                          <div style={{color:t.muted,fontSize:F.xxs,fontFamily:"monospace"}}>{item.l}</div>
                          <div style={{color:t.cyan,fontSize:F.sm,fontWeight:"bold",fontFamily:"monospace"}}>{item.v}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                  <button onClick={()=>onApply(res.p)} style={{background:`${t.acc}18`,border:`1.5px solid ${t.acc}`,borderRadius:8,
                    color:t.acc,fontSize:F.sm,fontWeight:"bold",padding:"9px 20px",cursor:"pointer",fontFamily:"monospace",whiteSpace:"nowrap"}}>
                    ✓ Terapkan
                  </button>
                </div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(95px,1fr))",gap:8}}>
                  {[
                    {l:"Efisiensi",v:`${res.r.efficiency}%`,k:"efficiency"},
                    {l:"CO Exit",  v:`${res.r.CO_exit}ppm`, k:"CO_exit",inv:true},
                    {l:"NOx",      v:`${res.r.NOx_exit}ppm`,k:"NOx_exit",inv:true},
                    {l:"PM2.5",    v:`${res.r.PM25_exit}`,  k:"PM25_exit",inv:true},
                    {l:"Lambda λ", v:`${res.r.lambda}`,     k:"lambda"},
                    {l:"Draft",    v:`${res.r.draft_Pa}Pa`, k:"draft_Pa"},
                  ].map((m,i)=>(
                    <div key={i} style={{background:t.inp,borderRadius:6,padding:"8px 10px",textAlign:"center"}}>
                      <div style={{color:t.muted,fontSize:F.xxs,fontFamily:"monospace",marginBottom:3}}>{m.l}</div>
                      <div style={{color:mColor(m.k,res.r),fontSize:F.sm,fontWeight:"bold",fontFamily:"monospace"}}>
                        {m.v}{delta(m.k,res.r,m.inv)}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── INITIAL PARAMS ──────────────────────────────────────────────── */
const DEF={d_port:.10,L_horiz:.35,d_riser:.10,H_riser:.60,feed_rate_kg_h:2.0,LHV_MJkg:15.0,
  moisture_pct:15,primary_air_Lmin:60,T_primary_C:25,T_secondary_C:25,insulation:70,fuelType:"wood",
  injections:[{id:1,h_pct:30,flow_Lmin:20},{id:2,h_pct:60,flow_Lmin:15}],riserSections:[]};

/* ─── MAIN APP ────────────────────────────────────────────────────── */
export default function App(){
  const [params,setParams]=useState(DEF);
  const [result,setResult]=useState(()=>simulate(DEF));
  const [themeKey,setThemeKey]=useState('dark');
  const t=TH[themeKey];
  const [sbW,setSbW]=useState(300);
  const [sbOpen,setSbOpen]=useState(true);
  const [activeTab,setActiveTab]=useState('temp');
  const dragging=useRef(false);
  const injId=useRef(3),secId=useRef(1);

  const set=useCallback((k,v)=>setParams(p=>({...p,[k]:v})),[]);
  const setFuel=useCallback(ft=>{const f=FUELS[ft];setParams(p=>({...p,fuelType:ft,LHV_MJkg:f.LHV,moisture_pct:f.mc}));},[]);
  useEffect(()=>{ setResult(simulate(params)); },[params]);

  // Sidebar drag resize
  useEffect(()=>{
    const mv=e=>{if(!dragging.current)return;setSbW(Math.max(220,Math.min(540,e.clientX)));};
    const up=()=>{dragging.current=false;};
    window.addEventListener('mousemove',mv);window.addEventListener('mouseup',up);
    return()=>{window.removeEventListener('mousemove',mv);window.removeEventListener('mouseup',up);};
  },[]);

  const addInj=()=>{const id=injId.current++;setParams(p=>({...p,injections:[...p.injections,{id,h_pct:50,flow_Lmin:10}]}));};
  const removeInj=id=>setParams(p=>({...p,injections:p.injections.filter(i=>i.id!==id)}));
  const updInj=(id,k,v)=>setParams(p=>({...p,injections:p.injections.map(i=>i.id===id?{...i,[k]:v}:i)}));
  const addSec=()=>{const id=secId.current++;setParams(p=>({...p,riserSections:[...p.riserSections,{id,h_pct:50,d:+(p.d_riser*1.2).toFixed(3)}]}));};
  const removeSec=id=>setParams(p=>({...p,riserSections:p.riserSections.filter(s=>s.id!==id)}));
  const updSec=(id,k,v)=>setParams(p=>({...p,riserSections:p.riserSections.map(s=>s.id===id?{...s,[k]:v}:s)}));
  const applyOpt=useCallback(optP=>{setParams(p=>({...p,primary_air_Lmin:optP.primary_air_Lmin,T_primary_C:optP.T_primary_C,T_secondary_C:optP.T_secondary_C,injections:optP.injections}));setActiveTab('temp');},[]);

  const CHARTS={
    temp:    {label:"🌡 Suhu",    lines:[{key:"T_C",    name:"Suhu",    color:"#f97316",unit:"°C"}],     yLabel:"T (°C)"},
    co:      {label:"💨 CO/NOx", lines:[{key:"CO_ppm", name:"CO",      color:"#ef4444",unit:"ppm"},{key:"NOx",name:"NOx",color:"#a78bfa",unit:"ppm"}],yLabel:"ppm"},
    vel:     {label:"💨 Aliran", lines:[{key:"v",      name:"Velocity",color:"#22d3ee",unit:"m/s"},{key:"dP",name:"Draft",color:"#86efac",unit:"Pa"}],yLabel:"v/ΔP"},
    pm:      {label:"🌫 PM2.5",  lines:[{key:"PM25",   name:"PM2.5",   color:"#fb923c",unit:"mg/MJ"}],   yLabel:"PM2.5"},
    diam:    {label:"📐 Diameter",lines:[{key:"d_local",name:"⌀ Riser",color:"#06b6d4",unit:"m"}],       yLabel:"d (m)"},
    opt:     {label:"🔧 Optimasi",lines:[],yLabel:""},
  };
  const aC=CHARTS[activeTab];
  const fuel=FUELS[params.fuelType]||FUELS.wood;

  const sBtnStyle=(active)=>({
    background:active?t.card:t.inp,border:`1px solid ${active?t.acc:t.bdr}`,borderRadius:5,
    color:active?t.acc:t.muted,fontSize:F.sm,padding:"5px 9px",cursor:"pointer",fontFamily:"monospace",whiteSpace:"nowrap"
  });

  const cardStyle={background:t.tag,borderRadius:6,padding:"9px 13px",border:`1px solid ${t.bdr}`};

  return(
    <div style={{display:"flex",height:"100vh",background:t.bg,fontFamily:"monospace",overflow:"hidden",color:t.txt}}>

      {/* ── SIDEBAR ─────────────────────────────────────────── */}
      {sbOpen&&(
        <div style={{width:sbW,minWidth:sbW,maxWidth:sbW,background:t.sb,borderRight:`1px solid ${t.bdr}`,
          overflowY:"auto",padding:"17px 15px",flexShrink:0}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20,
            paddingBottom:11,borderBottom:`1px solid ${t.acc}33`}}>
            <span style={{color:t.acc,fontSize:F.hdr,fontWeight:"bold",letterSpacing:".09em"}}>⚙ INPUT</span>
            <button onClick={()=>setSbOpen(false)} style={{background:t.card,border:`1px solid ${t.bdr}`,
              borderRadius:6,color:t.muted,fontSize:F.sm,padding:"4px 11px",cursor:"pointer"}}>◀</button>
          </div>

          <Sec title="Combustion Chamber" color={t.acc} t={t}>
            <Slider t={t} label="Port Diameter" value={params.d_port} min={.05} max={.25} step={.005} unit=" m" onChange={v=>set("d_port",v)}/>
            <Slider t={t} label="Panjang Horizontal" value={params.L_horiz} min={.15} max={.80} step={.01} unit=" m" onChange={v=>set("L_horiz",v)}/>
          </Sec>

          <Sec title="Heat Riser" color="#fb923c" t={t}>
            <Slider t={t} label="Diameter Dasar" value={params.d_riser} min={.05} max={.25} step={.005} unit=" m" warn={!result.area_ok} onChange={v=>set("d_riser",v)}/>
            <Slider t={t} label="Tinggi Riser (H)" value={params.H_riser} min={.20} max={1.50} step={.01} unit=" m" onChange={v=>set("H_riser",v)}/>
            {!result.area_ok&&<div style={{color:t.danger,fontSize:F.xs,marginTop:-6,marginBottom:13,padding:"6px 10px",
              background:`${t.danger}11`,borderRadius:4,borderLeft:`2px solid ${t.danger}`}}>
              ⚠ Ratio {result.area_ratio} — target 0.85–1.15
            </div>}
            <div style={{color:t.muted,fontSize:F.xs,marginTop:-4,marginBottom:15}}>H/d: <span style={{color:(params.H_riser/params.d_riser)>=5?t.ok:t.warn,fontWeight:"bold"}}>{(params.H_riser/params.d_riser).toFixed(1)} {(params.H_riser/params.d_riser)>=5?"✓":"(min 5)"}</span></div>
            <div style={{color:t.cyan,fontSize:F.xs,letterSpacing:".12em",marginBottom:10,paddingBottom:6,
              borderBottom:`1px solid ${t.cyan}22`,textTransform:"uppercase",fontWeight:"bold"}}>Ubah Diameter</div>
            {params.riserSections.map(sec=>(
              <div key={sec.id} style={{background:t.inp,border:`1px solid ${t.bdr}`,borderRadius:7,padding:"11px 13px",marginBottom:11}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:9}}>
                  <span style={{color:t.cyan,fontSize:F.sm}}>⌀{(sec.d*100).toFixed(0)}cm @{sec.h_pct}%</span>
                  <button onClick={()=>removeSec(sec.id)} style={{background:"none",border:`1px solid ${t.danger}44`,borderRadius:4,color:t.danger,fontSize:F.xs,padding:"2px 8px",cursor:"pointer"}}>✕</button>
                </div>
                <Slider t={t} label="Posisi (%H)" value={sec.h_pct} min={5} max={95} step={5} unit="%" color={t.cyan} onChange={v=>updSec(sec.id,"h_pct",v)}/>
                <Slider t={t} label="Diameter baru" value={sec.d} min={.05} max={.25} step={.005} unit=" m" color={t.cyan} onChange={v=>updSec(sec.id,"d",v)}/>
              </div>
            ))}
            <button onClick={addSec} style={{width:"100%",background:`${t.cyan}0e`,border:`1px dashed ${t.cyan}44`,
              borderRadius:6,color:t.cyan,fontSize:F.sm,padding:"9px",cursor:"pointer",fontFamily:"monospace",marginBottom:2}}>
              + Tambah Ubah Diameter
            </button>
          </Sec>

          <Sec title="Bahan Bakar" color="#fbbf24" t={t}>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:7,marginBottom:15}}>
              {Object.entries(FUELS).map(([k,f])=>(
                <button key={k} onClick={()=>setFuel(k)} style={{
                  background:params.fuelType===k?`${f.c}22`:t.card,border:`1px solid ${params.fuelType===k?f.c:t.bdr}`,
                  borderRadius:6,color:params.fuelType===k?f.c:t.muted,fontSize:F.xs,padding:"9px 7px",
                  cursor:"pointer",fontFamily:"monospace",textAlign:"center",transition:"all .2s",lineHeight:1.4}}>
