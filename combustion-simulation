            <button onClick={addInj} style={{width:"100%",background:`${t.cyan}0e`,border:`1px dashed ${t.cyan}44`,
              borderRadius:6,color:t.cyan,fontSize:F.sm,padding:"9px",cursor:"pointer",fontFamily:"monospace"}}>
              + Tambah Titik Injeksi
            </button>
          </Sec>
        </div>
      )}

      {/* ── DRAG HANDLE ─────────────────────────────────────── */}
      {sbOpen&&(
        <div style={{width:6,flexShrink:0,cursor:"col-resize",display:"flex",alignItems:"center",justifyContent:"center",
          background:"transparent",borderRight:`1px solid ${t.bdr}`,zIndex:10}}
          onMouseDown={()=>{dragging.current=true;}}>
          <div style={{width:3,height:44,borderRadius:3,background:t.bdr,opacity:.7}}/>
        </div>
      )}

      {/* ── MAIN AREA ────────────────────────────────────────── */}
      <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden",minWidth:0}}>

        {/* HEADER */}
        <div style={{background:t.sb,borderBottom:`1px solid ${t.bdr}`,padding:"10px 20px",
          display:"flex",alignItems:"center",gap:12,flexShrink:0,minHeight:65}}>
          {!sbOpen&&<button onClick={()=>setSbOpen(true)} style={{...sBtnStyle(false),marginRight:4}}>▶ Menu</button>}
          <div style={{width:7,height:30,background:t.acc,borderRadius:2,boxShadow:`0 0 14px ${t.acc}aa`}}/>
          <div>
            <div style={{fontSize:F.hdr,fontWeight:"bold",color:t.acc,letterSpacing:".07em"}}>WASTE COMBUSTION SIMULATION</div>
            <div style={{fontSize:F.xs,color:t.muted}}>Winiarski · Fluid Dynamics · {fuel.icon} {fuel.name}</div>
          </div>
          <div style={{marginLeft:"auto",display:"flex",gap:16,alignItems:"center",flexWrap:"wrap"}}>
            {[
              {l:"DAYA API",  v:`${result.Q_kW}kW`,    c:t.acc},
              {l:"EFISIENSI", v:`${result.efficiency}%`,c:+result.efficiency>35?t.ok:t.warn},
              {l:"EXIT CO",   v:`${result.CO_exit}ppm`, c:result.CO_exit<200?t.ok:result.CO_exit<700?t.warn:t.danger},
              {l:"DRAFT",     v:`${result.draft_Pa}Pa`, c:t.cyan},
            ].map((kpi,i)=>(
              <div key={i} style={{textAlign:"center"}}>
                <div style={{color:t.muted,fontSize:F.xxs,letterSpacing:".12em"}}>{kpi.l}</div>
                <div style={{color:kpi.c,fontSize:F.kpi,fontWeight:"bold",lineHeight:1.15,textShadow:`0 0 14px ${kpi.c}88`}}>{kpi.v}</div>
              </div>
            ))}
            <button onClick={()=>setThemeKey(k=>k==='dark'?'light':'dark')} style={{
              background:t.card,border:`1px solid ${t.bdr}`,borderRadius:9,
              color:t.txt,fontSize:F.lg,padding:"7px 14px",cursor:"pointer",marginLeft:6}} title="Ganti tema">
              {themeKey==='dark'?"☀️":"🌙"}
            </button>
          </div>
        </div>

        {/* SCHEMATIC + KPI */}
        <div style={{display:"flex",flex:"0 0 420px",overflow:"hidden",borderBottom:`1px solid ${t.bdr}`}}>
          <div style={{width:340,flexShrink:0,borderRight:`1px solid ${t.bdr}`,
            display:"flex",alignItems:"center",justifyContent:"center",background:"#050d1a"}}>
            <Schematic params={params} result={result}/>
          </div>
          <div style={{flex:1,padding:"16px 20px",overflowY:"auto",background:t.panelBg}}>
            <div style={{fontSize:F.sm,color:t.acc,letterSpacing:".15em",marginBottom:15,textTransform:"uppercase",
              borderBottom:`1px solid ${t.hlBdr}`,paddingBottom:7,fontWeight:"bold"}}>Output Summary</div>
            <Gauge t={t} label="Efisiensi Termal" value={+result.efficiency} max={70} unit="%" warn={30} good={40}/>
            <Gauge t={t} label="Suhu Pembakaran"  value={result.T_flame_C}   max={1400} unit="°C" warn={600} good={800}/>
            <Gauge t={t} label="Suhu Gas Keluar"  value={result.T_exit_C}    max={500}  unit="°C" warn={0}   good={150}/>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginTop:15}}>
              {[
                {l:"Fire Power",     v:`${result.Q_kW} kW`,        c:t.acc},
                {l:"Natural Draft",  v:`${result.draft_Pa} Pa`,     c:t.cyan},
                {l:"A_port",         v:`${result.A_port_cm2} cm²`,  c:t.muted},
                {l:"A_riser",        v:`${result.A_riser_cm2} cm²`, c:t.muted},
                {l:"Area Ratio",     v:result.area_ratio,           c:result.area_ok?t.ok:t.danger},
                {l:"Lambda λ",       v:result.lambda,               c:+result.lambda>0.9&&+result.lambda<1.8?t.ok:t.warn},
                {l:"Exit CO",        v:`${result.CO_exit} ppm`,     c:result.CO_exit<200?t.ok:t.danger},
                {l:"Exit NOx",       v:`${result.NOx_exit} ppm`,    c:+result.NOx_exit<50?t.ok:t.warn},
                {l:"Exit PM2.5",     v:`${result.PM25_exit}mg/MJ`,  c:+result.PM25_exit<10?t.ok:t.warn},
                {l:"T Pembakaran",   v:`${result.T_flame_C}°C`,     c:result.T_flame_C>=600?t.ok:t.danger},
                {l:"Suhu Primer",    v:`${params.T_primary_C}°C`,   c:t.blue},
                {l:"Suhu Sekunder",  v:`${params.T_secondary_C}°C`, c:t.cyan},
              ].map((item,i)=>(
                <div key={i} style={cardStyle}>
                  <div style={{color:t.muted,fontSize:F.xxs,marginBottom:4}}>{item.l}</div>
                  <div style={{color:item.c,fontSize:F.md,fontWeight:"bold",wordBreak:"break-all"}}>{item.v}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* TABS + CONTENT */}
        <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden"}}>
          <div style={{display:"flex",gap:6,padding:"10px 16px",flexShrink:0,borderBottom:`1px solid ${t.bdr}`,
            flexWrap:"wrap",background:t.panelBg}}>
            {Object.entries(CHARTS).map(([k,c])=>(
              <button key={k} onClick={()=>setActiveTab(k)} style={{
                background:activeTab===k?`${t.acc}18`:t.card,border:`1.5px solid ${activeTab===k?t.acc:t.bdr}`,
                borderRadius:6,color:activeTab===k?t.acc:t.btnTxt,fontSize:F.sm,padding:"7px 14px",
                cursor:"pointer",fontFamily:"monospace",letterSpacing:".04em",transition:"all .2s",
                fontWeight:activeTab===k?"bold":"normal"}}>
                {c.label}
              </button>
            ))}
            <div style={{marginLeft:"auto",color:t.dim,fontSize:F.xs,alignSelf:"center"}}>
              {result.profile.length}pts · {params.riserSections.length}Δ⌀ · {params.injections.filter(i=>i.flow_Lmin>0).length}inj
            </div>
          </div>
          <div style={{flex:1,overflow:"hidden",display:"flex"}}>
            {activeTab==='opt'?(
              <OptPanel params={params} curResult={result} t={t} onApply={applyOpt}/>
            ):(
              <div style={{flex:1,padding:"10px 14px",minHeight:0,background:t.bg}}>
                <ResponsiveContainer width="100%" height="100%">
                  <ComposedChart data={result.profile} margin={{top:6,right:22,bottom:24,left:8}}>
                    <CartesianGrid stroke={t.gridCol} strokeDasharray="3 3"/>
                    <XAxis dataKey="h" stroke={t.bdr} tick={{fill:t.muted,fontSize:F.xs,fontFamily:"monospace"}}
                      label={{value:"Ketinggian Riser (m)",position:"insideBottom",offset:-14,fill:t.muted,fontSize:F.sm}}/>
                    <YAxis stroke={t.bdr} tick={{fill:t.muted,fontSize:F.xs,fontFamily:"monospace"}}
                      label={{value:aC.yLabel,angle:-90,position:"insideLeft",fill:t.muted,fontSize:F.sm,dy:40}}/>
                    <Tooltip content={<CTip/>}/>
                    <Legend wrapperStyle={{fontSize:F.sm,fontFamily:"monospace",color:t.muted}}/>
                    {params.injections.filter(i=>i.flow_Lmin>0).map((inj,i)=>{
                      const hv=+(inj.h_pct/100*params.H_riser).toFixed(3);
                      return <ReferenceLine key={i} x={hv} stroke={t.cyan+"55"} strokeDasharray="4 2"
                        label={{value:`AIR₂@${inj.h_pct}%`,position:"top",fill:t.cyan,fontSize:F.xxs}}/>;
                    })}
                    {params.riserSections.map((sec,i)=>{
                      const hv=+(sec.h_pct/100*params.H_riser).toFixed(3);
                      return <ReferenceLine key={`s${i}`} x={hv} stroke="#06b6d455" strokeDasharray="2 4"
                        label={{value:`⌀${(sec.d*100).toFixed(0)}@${sec.h_pct}%`,position:"insideTopRight",fill:"#06b6d4",fontSize:F.xxs}}/>;
                    })}
                    {aC.lines.map(l=>(
                      <Area key={l.key} type="monotone" dataKey={l.key} name={l.name}
                        stroke={l.color} fill={l.color+"18"} strokeWidth={2.5} dot={false}
                        activeDot={{r:5,fill:l.color}} unit={l.unit}/>
                    ))}
                  </ComposedChart>
                </ResponsiveContainer>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}
